# API settings
# Copy this file to .env and fill in the values.

# JWT — generate with: openssl rand -hex 32
API_JWT_SECRET=change-me

# JWT token lifetime in minutes
API_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Admin user bootstrapped at startup
# Generate hash with:
#   uv run python -c "import bcrypt; print(bcrypt.hashpw(b'your-password', bcrypt.gensalt()).decode())"
API_ADMIN_USERNAME=admin
API_ADMIN_PASSWORD_HASH=change-me